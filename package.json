{
  "name": "wemos-d1-pro",
  "version": "1.0.0",
  "description": "Aplikasi kontrol Wemos D1 dengan alarm dan notifikasi real-time",
  "main": "index.js",
  "scripts": {
    "start": "cordova serve",
    "build": "cordova build android --release",
    "build:debug": "cordova build android --debug",
    "run": "cordova run android",
    "run:debug": "cordova run android --debug",
    "prepare": "cordova prepare",
    "clean": "cordova clean",
    "check:requirements": "cordova requirements android",
    "sign:apk": "cd platforms/android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "cordova": "^12.0.0",
    "cordova-android": "^13.0.0"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Wemos Development Team",
